694\uac00 \uc5ec\uc804\ud788 \uacac\uace0\ud568\uc744 \uc2dc\uc0ac\ud569\ub2c8\ub2e4.\n\n## \uc8fc\uc758\ud560 \uc810\n\n**\uac70\uc2dc\uc801 \ubd88\ud655\uc2e4\uc131\uc740 \uc5ec\uc804\ud569\ub2c8\ub2e4.** \ud2b8\ub7fc\ud504 \ud589\uc815\ubd80\uc758 \uad00\uc138 \uc815\ucc45\uc774 2\uc6d4 24\uc77c\ubd80\ud130 \uc2dc\ud589\ub418\uba74\uc11c \uc2dc\uc7a5 \ubcc0\ub3d9\uc131\uc774 \ud655\ub300\ub420 \uc804\ub9dd\uc785\ub2c8\ub2e4.[1] \uae08\uacfc \uc740 \uac19\uc740 \uc548\uc804\uc790\uc0b0\uc774 \uc0c1\uc2b9\ud558\uace0 \uc788\ub294 \uac83\uc740 \ud22c\uc790\uc790\ub4e4\uc774 \uc5ec\uc804\ud788 \ubc29\uc5b4\uc801 \ud3ec\uc9c0\uc158\uc744 \uc720\uc9c0\ud558\uace0 \uc788\uc74c\uc744 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4.[6]\n\n## \ud22c\uc790 \uc804\ub7b5\n\n\ub2e8\uae30\uc801\uc73c\ub85c\ub294 \ud604\uae08\uacfc \uae08 \ube44\uc911\uc744 \uc720\uc9c0\ud558\uba70 \uad00\ub9dd\ud558\ub418, \uc911\uc7a5\uae30\uc801\uc73c\ub85c\ub294 \uc815\ucc45 \ubd88\ud655\uc2e4\uc131 \ud574\uc18c \uc2dc\uc810\uc5d0 \uae30\uc220\u00b7\uc81c\uc870 \uc139\ud130 \uc800\uc810 \ub9e4\uc218\ub97c \uace0\ub824\ud560 \ud544\uc694\uac00 \uc788\uc2b5\ub2c8\ub2e4.[1]"},"fear_greed":{"color":"yellow","label":"Neutral","score":49.7,"source":"vix_derived"},"market_data":{"bonds":{"^FVX":{"change":2.37,"high_52w":4.22,"low_52w":null,"name":"5Y Treasury","pct_from_high":-5.0,"prev_close":3.92,"price":4.01},"^IRX":{"change":0.17,"high_52w":4.3,"low_52w":null,"name":"3M T-Bill","pct_from_high":-15.96,"prev_close":3.61,"price":3.62},"^TNX":{"change":2.57,"high_52w":4.63,"low_52w":null,"name":"10Y Treasury","pct_from_high":-5.14,"prev_close":4.28,"price":4.39}},"commodities":{"BTC-USD":{"change":-0.16,"high_52w":126198.07,"low_52w":60074.2,"name":"Bitcoin","pct_from_high":-44.21,"prev_close":70522.59,"price":70410.24},"CL=F":{"change":2.17,"high_52w":119.48,"low_52w":54.98,"name":"Crude Oil","pct_from_high":-17.79,"prev_close":96.14,"price":98.23},"GC=F":{"change":-0.56,"high_52w":5586.2,"low_52w":2949.7,"name":"